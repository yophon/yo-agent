{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "isolatedModules": true,

    "strict": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,

    "noEmit": true,
    "declaration": false,

    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@yo-agent/protocol": ["packages/protocol/src/index.ts"],
      "@yo-agent/provider": ["packages/provider/src/index.ts"],
      "@yo-agent/tools": ["packages/tools/src/index.ts"],
      "@yo-agent/store": ["packages/store/src/index.ts"],
      "@yo-agent/kernel": ["packages/kernel/src/index.ts"],
      "@yo-agent/surface-cli": ["packages/surface-cli/src/index.ts"],
      "@yo-agent/surface-rpc": ["packages/surface-rpc/src/index.ts"]
    }
  }
}
