{
  "extends": "./tsconfig.base.json",
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "packages/*/scripts/**/*.ts",
    "apps/*/src/**/*.ts",
    "vitest.config.ts"
  ],
  // web-demo/web-console 需要 DOM lib，用各自 tsconfig 单独 typecheck（根 typecheck 脚本串跑）。
  "exclude": ["apps/web-demo", "apps/web-console"]
}
